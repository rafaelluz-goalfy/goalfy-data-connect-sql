$env:APP_ENV="development"

# DB interno (mesmo do orchestrator)
$env:DB_HOST="localhost"
$env:DB_PORT="5432"
$env:DB_NAME="goalfy_data_connect"
$env:DB_USER="postgres"
$env:DB_PASSWORD="postgres"
$env:DB_SSLMODE="disable"

# Kafka (IMPORTANTÍSSIMO)
$env:KAFKA_BROKERS="localhost:9092"

# Worker config
$env:WORKER_CONSUMER_GROUP="goalfy-data-connect-sql"
$env:WORKER_TOPICS="data.connect.sync.requested"

# Secrets
$env:SECRET_postgres="postgres"